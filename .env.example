# Copiar este archivo como .env y completar los valores

# Servidor
PORT=8000

# Base de datos
DATABASE_URL=sqlite:///./data/news.db

# Scheduler (hora de fetch diario, formato HH:MM)
DAILY_FETCH_TIME=06:00

# RSS feed
FEED_TITLE=Daily News Briefing
FEED_DESCRIPTION=Tu resumen diario de noticias
FEED_BASE_URL=http://localhost:8000
